# Docker Postgres
POSTGRES_PORT=5432
POSTGRES_USER=memoryos
POSTGRES_PASSWORD=memoryos
POSTGRES_DB=memoryos

# App database connection
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=memoryos
PG_USER=memoryos
PG_PASSWORD=memoryos

# Docker Redis Stack (RediSearch + vector search + RedisInsight UI)
REDIS_STACK_VERSION=7.4.0-v1
REDIS_PORT=6379
REDIS_INSIGHT_PORT=8001
REDIS_PASSWORD=
# Optional: override redis-stack-server args (append --requirepass when needed)
REDIS_ARGS=--appendonly yes

# App Redis Stack connection
REDIS_HOST=localhost
REDIS_DB=0
REDIS_VECTOR_INDEX=worldcup:vectors
# REDIS_URL=redis://localhost:6379/0
# With password: REDIS_URL=redis://:your_password@localhost:6379/0
# REDIS_ARGS=--appendonly yes --requirepass your_password

# LLM (DashScope OpenAI-compatible)
API_KEY=
MODEL_NAME=qwen3-max
API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024

# Agent / workflow
AGENT_DEBUG=false
AGENT_MAX_ITERATIONS=10
DEFAULT_WORKFLOW=simple_qa
WORKFLOW_AUTO_ROUTE=true

# Router (small LLM for ambiguous session turns; default off)
ROUTER_LLM_ENABLED=false
ROUTER_MODEL_NAME=qwen-turbo
ROUTER_CONFIDENCE_THRESHOLD=0.7

# Complex flow SQL replan / summarize (defaults to ROUTER_MODEL_NAME when unset)
# COMPLEX_FLOW_MODEL_NAME=qwen-turbo

# Session memory (Redis)
MEMORY_TTL_DAYS=7
MEMORY_MAX_TURNS=10
MEMORY_MAX_TOKENS=4000

# Logging
LOG_LEVEL=INFO

# LangSmith (optional — traces LangChain agent runs)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=worldcup-rag
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# API server
APP_HOST=0.0.0.0
APP_PORT=8000
BENCHMARK_API_BASE=http://localhost:8000
